# Скопируй в .env и заполни реальными значениями (.env в .gitignore)
# Единый env-файл для всего docker compose и локального dev gateway.

# LiteLLM
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
LITELLM_MASTER_KEY=sk-litellm-internal-key

# Gateway
# Порт, который публикуется наружу (в контейнере gateway всегда слушает 8080).
GATEWAY_PORT=8080
# Секрет для admin-эндпоинтов (/admin/*) — bootstrap юзеров и ключей.
ADMIN_TOKEN=
# Минимальный баланс для пропуска запроса (NUMERIC). Ниже/равно — 402. По умолч. 0.
BILLING_MIN_BALANCE=0

# Крипто-пополнение (Stage 5). Пусто → приём депозитов выключен, worker не стартует.
# Account-level xpub (m/44'/195'/0'), watch-only. Mnemonic держи ОФФЛАЙН, не сюда.
TRON_XPUB=
# По умолчанию testnet Nile; для боевой сети — https://api.trongrid.io
TRONGRID_URL=https://nile.trongrid.io
TRONGRID_API_KEY=
# TRC-20 контракт USDT (адрес зависит от сети: Nile vs mainnet).
USDT_CONTRACT_ADDRESS=
USDT_DECIMALS=6
CRYPTO_MIN_CONFIRMATIONS=19
CRYPTO_POLL_INTERVAL_SECONDS=30

# Postgres
POSTGRES_USER=cryptophic
POSTGRES_PASSWORD=
POSTGRES_DB=cryptophic
# В docker host = postgres (имя сервиса); локально (pnpm dev) — localhost.
DATABASE_URL=postgres://cryptophic:@localhost:5432/cryptophic
TRON_XPUB=
